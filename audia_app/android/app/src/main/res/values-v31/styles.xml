<?xml version="1.0" encoding="utf-8"?>
<!--
    Overrides para Android 12+ (API 31+).
    Usa los atributos nativos android:windowSplashScreen* para
    garantizar que la splash nativa sea invisible en todos los dispositivos.
-->
<resources>
    <style name="Theme.Audia.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/black</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_transparent</item>
        <item name="windowSplashScreenIconBackgroundColor">@android:color/black</item>
        <item name="postSplashScreenTheme">@style/NormalTheme</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
</resources>
